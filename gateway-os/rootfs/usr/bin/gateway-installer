#!/bin/bash
set -e

# Gateway OS Installer
# Installs Gateway OS to hard drive from live ISO

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log() { echo -e "${BLUE}[INSTALLER] $1${NC}"; }
success() { echo -e "${GREEN}[SUCCESS] $1${NC}"; }
warn() { echo -e "${YELLOW}[WARNING] $1${NC}"; }
error() { echo -e "${RED}[ERROR] $1${NC}"; exit 1; }
info() { echo -e "${CYAN}[INFO] $1${NC}"; }

# Configuration
GATEWAY_VERSION="1.0.0"
MIN_DISK_SIZE_GB=4
RECOMMENDED_DISK_SIZE_GB=8

show_banner() {
    clear
    cat << 'EOF'
╔══════════════════════════════════════════════════════════════╗
║                    Gateway OS Installer                     ║
║                                                              ║
║         Install VPN Gateway OS to Hard Drive/SSD            ║
╚══════════════════════════════════════════════════════════════╝
EOF
    echo
    info "Version: $GATEWAY_VERSION"
    info "This installer will permanently install Gateway OS to your hard drive."
    warn "WARNING: All data on the target drive will be PERMANENTLY ERASED!"
    echo
}

check_live_system() {
    log "Checking if running from live system..."
    
    if [[ ! -f /.live_system ]]; then
        if grep -q "root=/dev/ram0" /proc/cmdline; then
            touch /.live_system
        else
            error "This installer must be run from the Gateway OS live system!"
        fi
    fi
    
    success "Running from live system"
}

detect_disks() {
    log "Detecting available disks..."
    
    DISKS=()
    while IFS= read -r -d '' disk; do
        disk_name=$(basename "$disk")
        disk_size=$(lsblk -bdn -o SIZE "$disk" 2>/dev/null | head -1)
        disk_size_gb=$((disk_size / 1024 / 1024 / 1024))
        disk_model=$(lsblk -dn -o MODEL "$disk" 2>/dev/null | head -1 | xargs)
        
        # Skip if too small
        if [[ $disk_size_gb -lt $MIN_DISK_SIZE_GB ]]; then
            continue
        fi
        
        # Skip USB devices (usually the live USB)
        if [[ $(udevadm info --name="$disk" | grep -c "ID_BUS=usb") -gt 0 ]]; then
            continue
        fi
        
        DISKS+=("$disk:$disk_size_gb GB:$disk_model")
    done < <(find /dev -name 'sd[a-z]' -o -name 'nvme[0-9]n[0-9]' -o -name 'mmcblk[0-9]' -print0 2>/dev/null)
    
    if [[ ${#DISKS[@]} -eq 0 ]]; then
        error "No suitable disks found! Minimum size: ${MIN_DISK_SIZE_GB}GB"
    fi
    
    success "Found ${#DISKS[@]} suitable disk(s)"
}

select_disk() {
    echo
    info "Available disks for installation:"
    echo
    
    for i in "${!DISKS[@]}"; do
        IFS=':' read -r disk size model <<< "${DISKS[i]}"
        printf "%2d) %-12s %-10s %s\n" $((i+1)) "$disk" "$size" "$model"
    done
    
    echo
    while true; do
        read -p "Select disk number (1-${#DISKS[@]}): " selection
        
        if [[ "$selection" =~ ^[0-9]+$ ]] && [[ $selection -ge 1 ]] && [[ $selection -le ${#DISKS[@]} ]]; then
            SELECTED_DISK_INDEX=$((selection-1))
            IFS=':' read -r TARGET_DISK TARGET_SIZE TARGET_MODEL <<< "${DISKS[SELECTED_DISK_INDEX]}"
            break
        else
            error "Invalid selection. Please enter a number between 1 and ${#DISKS[@]}."
        fi
    done
    
    echo
    warn "Selected disk: $TARGET_DISK ($TARGET_SIZE, $TARGET_MODEL)"
    warn "ALL DATA ON THIS DISK WILL BE PERMANENTLY ERASED!"
    echo
    
    read -p "Are you absolutely sure? Type 'YES' to continue: " confirmation
    if [[ "$confirmation" != "YES" ]]; then
        error "Installation cancelled by user."
    fi
}

show_disk_info() {
    log "Target disk information:"
    echo
    lsblk "$TARGET_DISK" || true
    echo
    
    if [[ -f "/sys/block/$(basename "$TARGET_DISK")/queue/rotational" ]]; then
        rotational=$(cat "/sys/block/$(basename "$TARGET_DISK")/queue/rotational")
        if [[ "$rotational" == "0" ]]; then
            info "Detected SSD - will enable optimizations"
        else
            info "Detected HDD - will use standard settings"
        fi
    fi
}

partition_disk() {
    log "Partitioning disk $TARGET_DISK..."
    
    # Unmount any existing partitions
    for part in "${TARGET_DISK}"*; do
        if [[ -b "$part" ]] && [[ "$part" != "$TARGET_DISK" ]]; then
            umount "$part" 2>/dev/null || true
        fi
    done
    
    # Clear partition table
    wipefs -af "$TARGET_DISK"
    sgdisk -Z "$TARGET_DISK"
    
    # Create GPT partition table with BIOS boot partition and EFI system partition
    sgdisk -o "$TARGET_DISK"
    
    # BIOS boot partition (for legacy BIOS compatibility)
    sgdisk -n 1:0:+1M -t 1:ef02 -c 1:"BIOS Boot" "$TARGET_DISK"
    
    # EFI System Partition
    sgdisk -n 2:0:+512M -t 2:ef00 -c 2:"EFI System" "$TARGET_DISK"
    
    # Root partition (rest of disk)
    sgdisk -n 3:0:0 -t 3:8300 -c 3:"Gateway Root" "$TARGET_DISK"
    
    # Wait for kernel to recognize new partitions
    sleep 2
    partprobe "$TARGET_DISK"
    sleep 2
    
    success "Disk partitioned successfully"
}

format_partitions() {
    log "Formatting partitions..."
    
    # Determine partition names
    if [[ "$TARGET_DISK" =~ nvme ]]; then
        EFI_PART="${TARGET_DISK}p2"
        ROOT_PART="${TARGET_DISK}p3"
    else
        EFI_PART="${TARGET_DISK}2"
        ROOT_PART="${TARGET_DISK}3"
    fi
    
    # Format EFI System Partition
    mkfs.fat -F32 -n "GATEWAY_EFI" "$EFI_PART"
    
    # Format root partition
    mkfs.ext4 -F -L "GATEWAY_ROOT" "$ROOT_PART"
    
    # Enable SSD optimizations if detected
    if [[ -f "/sys/block/$(basename "$TARGET_DISK")/queue/rotational" ]]; then
        rotational=$(cat "/sys/block/$(basename "$TARGET_DISK")/queue/rotational")
        if [[ "$rotational" == "0" ]]; then
            log "Enabling SSD optimizations..."
            tune2fs -o discard "$ROOT_PART"
        fi
    fi
    
    success "Partitions formatted successfully"
}

mount_partitions() {
    log "Mounting partitions..."
    
    # Create mount points
    mkdir -p /mnt/gateway
    mkdir -p /mnt/gateway/boot/efi
    
    # Mount root partition
    mount "$ROOT_PART" /mnt/gateway
    
    # Mount EFI partition
    mount "$EFI_PART" /mnt/gateway/boot/efi
    
    success "Partitions mounted"
}

install_system() {
    log "Installing Gateway OS system..."
    
    # Create basic directory structure
    mkdir -p /mnt/gateway/{bin,boot,dev,etc,home,lib,lib64,media,mnt,opt,proc,root,run,sbin,srv,sys,tmp,usr,var}
    mkdir -p /mnt/gateway/usr/{bin,lib,lib64,local,sbin,share}
    mkdir -p /mnt/gateway/var/{cache,lib,lock,log,opt,run,spool,tmp}
    mkdir -p /mnt/gateway/etc/{gateway,systemd,wireguard}
    
    # Copy system files from live environment
    log "Copying system files..."
    
    # Copy essential directories
    cp -a /bin/* /mnt/gateway/bin/ 2>/dev/null || true
    cp -a /sbin/* /mnt/gateway/sbin/ 2>/dev/null || true
    cp -a /usr/* /mnt/gateway/usr/ 2>/dev/null || true
    cp -a /lib/* /mnt/gateway/lib/ 2>/dev/null || true
    cp -a /lib64/* /mnt/gateway/lib64/ 2>/dev/null || true
    
    # Copy configuration files
    cp -a /etc/* /mnt/gateway/etc/ 2>/dev/null || true
    
    # Copy var directories
    cp -a /var/lib/* /mnt/gateway/var/lib/ 2>/dev/null || true
    
    # Remove live-system specific files
    rm -f /mnt/gateway/.live_system
    rm -f /mnt/gateway/etc/systemd/system/live-*
    
    success "System files copied"
}

configure_fstab() {
    log "Configuring filesystem table..."
    
    # Get UUIDs
    ROOT_UUID=$(blkid -s UUID -o value "$ROOT_PART")
    EFI_UUID=$(blkid -s UUID -o value "$EFI_PART")
    
    cat > /mnt/gateway/etc/fstab << EOF
# Gateway OS Filesystem Table
# <file system> <mount point> <type> <options> <dump> <pass>

UUID=$ROOT_UUID / ext4 defaults,noatime 0 1
UUID=$EFI_UUID /boot/efi vfat defaults,noatime 0 2

# Special filesystems
proc /proc proc defaults 0 0
sysfs /sys sysfs defaults 0 0
devpts /dev/pts devpts gid=5,mode=620 0 0
tmpfs /dev/shm tmpfs defaults 0 0
tmpfs /tmp tmpfs defaults,nodev,nosuid,size=1G 0 0
tmpfs /var/tmp tmpfs defaults,nodev,nosuid,size=512M 0 0
EOF
    
    success "Filesystem table configured"
}

install_bootloader() {
    log "Installing bootloader..."
    
    # Mount necessary filesystems for chroot
    mount --bind /dev /mnt/gateway/dev
    mount --bind /proc /mnt/gateway/proc
    mount --bind /sys /mnt/gateway/sys
    
    # Install GRUB2
    chroot /mnt/gateway grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=GatewayOS "$TARGET_DISK"
    chroot /mnt/gateway grub-install --target=i386-pc "$TARGET_DISK"
    
    # Create GRUB configuration
    cat > /mnt/gateway/etc/default/grub << EOF
GRUB_DEFAULT=0
GRUB_TIMEOUT=5
GRUB_DISTRIBUTOR="Gateway OS"
GRUB_CMDLINE_LINUX_DEFAULT="quiet splash"
GRUB_CMDLINE_LINUX="console=tty1 console=ttyS0,115200"
GRUB_TERMINAL="console serial"
GRUB_SERIAL_COMMAND="serial --speed=115200 --unit=0 --word=8 --parity=no --stop=1"
EOF
    
    # Generate GRUB configuration
    chroot /mnt/gateway grub-mkconfig -o /boot/grub/grub.cfg
    
    # Unmount chroot filesystems
    umount /mnt/gateway/dev
    umount /mnt/gateway/proc
    umount /mnt/gateway/sys
    
    success "Bootloader installed"
}

configure_system() {
    log "Configuring installed system..."
    
    # Set hostname
    echo "gateway" > /mnt/gateway/etc/hostname
    
    # Configure hosts file
    cat > /mnt/gateway/etc/hosts << EOF
127.0.0.1   localhost
127.0.1.1   gateway
::1         localhost ip6-localhost ip6-loopback
ff02::1     ip6-allnodes
ff02::2     ip6-allrouters
EOF
    
    # Enable gateway services
    chroot /mnt/gateway systemctl enable gateway-firstboot.service
    chroot /mnt/gateway systemctl enable gateway-manager.service
    chroot /mnt/gateway systemctl enable gateway-web.service
    chroot /mnt/gateway systemctl enable systemd-networkd.service
    chroot /mnt/gateway systemctl enable systemd-resolved.service
    chroot /mnt/gateway systemctl enable ssh.service
    
    # Mark for first boot setup
    rm -f /mnt/gateway/var/lib/gateway/.firstboot-complete
    
    success "System configured"
}

cleanup() {
    log "Cleaning up..."
    
    # Unmount filesystems
    umount /mnt/gateway/boot/efi 2>/dev/null || true
    umount /mnt/gateway 2>/dev/null || true
    
    success "Cleanup complete"
}

show_completion() {
    clear
    cat << 'EOF'
╔══════════════════════════════════════════════════════════════╗
║                Installation Complete!                       ║
╚══════════════════════════════════════════════════════════════╝
EOF
    echo
    success "Gateway OS has been successfully installed to $TARGET_DISK"
    echo
    info "Next steps:"
    echo "  1. Remove the installation media"
    echo "  2. Reboot the system"
    echo "  3. Complete first-boot setup"
    echo "  4. Access web interface at http://<gateway-ip>:8080"
    echo
    info "Default credentials:"
    echo "  Username: admin"
    echo "  Password: gateway123 (change immediately!)"
    echo
    warn "Please remove the installation media before rebooting!"
    echo
    
    read -p "Press Enter to reboot now, or Ctrl+C to stay in live system: "
    reboot
}

# Main installation function
main() {
    # Check if running as root
    if [[ $EUID -ne 0 ]]; then
        error "This installer must be run as root. Use: sudo $0"
    fi
    
    # Check for install parameter
    if ! grep -q "gateway.install=true" /proc/cmdline; then
        error "Please boot with 'Install Gateway OS' option from the boot menu"
    fi
    
    show_banner
    check_live_system
    detect_disks
    select_disk
    show_disk_info
    
    echo
    log "Starting installation process..."
    
    partition_disk
    format_partitions
    mount_partitions
    install_system
    configure_fstab
    install_bootloader
    configure_system
    cleanup
    
    show_completion
}

# Trap cleanup on exit
trap cleanup EXIT

# Run main function
main "$@"