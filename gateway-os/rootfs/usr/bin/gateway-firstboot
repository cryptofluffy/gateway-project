#!/bin/bash
set -e

# Gateway OS First Boot Setup Script
# Configures the system on first boot for optimal gateway operation

GATEWAY_DATA_DIR="/var/lib/gateway"
GATEWAY_CONFIG_DIR="/etc/gateway"
COMPLETE_FLAG="$GATEWAY_DATA_DIR/.firstboot-complete"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

log() {
    echo -e "${BLUE}[FIRSTBOOT] $1${NC}"
}

success() {
    echo -e "${GREEN}[SUCCESS] $1${NC}"
}

warn() {
    echo -e "${YELLOW}[WARNING] $1${NC}"
}

error() {
    echo -e "${RED}[ERROR] $1${NC}"
}

# Check if already completed
if [[ -f "$COMPLETE_FLAG" ]]; then
    log "First boot setup already completed"
    exit 0
fi

log "Starting Gateway OS first boot setup..."

# Create required directories
mkdir -p "$GATEWAY_DATA_DIR"
mkdir -p "$GATEWAY_CONFIG_DIR"
mkdir -p /var/log/gateway
mkdir -p /etc/wireguard

# Set up users and groups
setup_users() {
    log "Setting up gateway users..."
    
    # Create gateway-web user for web interface
    if ! id gateway-web &>/dev/null; then
        useradd -r -s /bin/false -d /usr/share/gateway/web -c "Gateway Web Interface" gateway-web
        success "Created gateway-web user"
    fi
    
    # Create gateway group
    if ! getent group gateway &>/dev/null; then
        groupadd gateway
        success "Created gateway group"
    fi
    
    # Add users to gateway group
    usermod -a -G gateway gateway-web
}

# Generate SSH host keys
setup_ssh() {
    log "Setting up SSH configuration..."
    
    # Generate host keys if they don't exist
    if [[ ! -f /etc/ssh/ssh_host_rsa_key ]]; then
        ssh-keygen -t rsa -b 4096 -f /etc/ssh/ssh_host_rsa_key -N "" -q
        success "Generated SSH RSA host key"
    fi
    
    if [[ ! -f /etc/ssh/ssh_host_ed25519_key ]]; then
        ssh-keygen -t ed25519 -f /etc/ssh/ssh_host_ed25519_key -N "" -q
        success "Generated SSH Ed25519 host key"
    fi
    
    # Configure SSH for security
    cat > /etc/ssh/sshd_config << 'EOF'
# Gateway OS SSH Configuration
Port 22
Protocol 2

# Authentication
PermitRootLogin no
PasswordAuthentication yes
PubkeyAuthentication yes
AuthorizedKeysFile .ssh/authorized_keys

# Security settings
AllowUsers admin
MaxAuthTries 3
ClientAliveInterval 300
ClientAliveCountMax 2

# Disable unused features
X11Forwarding no
AllowTcpForwarding no
AllowAgentForwarding no
PermitTunnel no

# Logging
SyslogFacility AUTH
LogLevel INFO
EOF
    
    success "SSH configuration updated"
}

# Set up default admin user
setup_admin_user() {
    log "Setting up admin user..."
    
    # Create admin user if it doesn't exist
    if ! id admin &>/dev/null; then
        useradd -m -s /bin/bash -G sudo,gateway admin
        
        # Set default password (should be changed on first login)
        echo "admin:gateway123" | chpasswd
        
        # Force password change on first login
        chage -d 0 admin
        
        success "Created admin user (default password: gateway123)"
        warn "Please change the default password immediately!"
    fi
    
    # Create SSH directory
    mkdir -p /home/admin/.ssh
    chmod 700 /home/admin/.ssh
    chown admin:admin /home/admin/.ssh
}

# Generate machine ID and hostname
setup_system_identity() {
    log "Setting up system identity..."
    
    # Generate unique machine ID
    if [[ ! -f /etc/machine-id ]]; then
        systemd-machine-id-setup
        success "Generated machine ID"
    fi
    
    # Set hostname based on MAC address for uniqueness
    local mac_addr=$(cat /sys/class/net/*/address | head -n1 | tr -d ':' | tail -c7)
    local hostname="gateway-${mac_addr}"
    
    echo "$hostname" > /etc/hostname
    hostnamectl set-hostname "$hostname"
    
    # Update /etc/hosts
    cat > /etc/hosts << EOF
127.0.0.1   localhost
127.0.1.1   $hostname
::1         localhost ip6-localhost ip6-loopback
ff02::1     ip6-allnodes
ff02::2     ip6-allrouters
EOF
    
    success "Hostname set to: $hostname"
}

# Configure network settings
setup_network() {
    log "Configuring network settings..."
    
    # Enable IP forwarding permanently
    echo 'net.ipv4.ip_forward = 1' > /etc/sysctl.d/99-gateway.conf
    echo 'net.ipv6.conf.all.forwarding = 1' >> /etc/sysctl.d/99-gateway.conf
    
    # Apply immediately
    sysctl -p /etc/sysctl.d/99-gateway.conf
    
    # Configure systemd-networkd for DHCP on all interfaces initially
    cat > /etc/systemd/network/10-dhcp.network << 'EOF'
[Match]
Name=eth* en*

[Network]
DHCP=yes
IPForward=yes

[DHCPv4]
UseDNS=yes
EOF
    
    # Enable systemd-networkd
    systemctl enable systemd-networkd
    systemctl enable systemd-resolved
    
    success "Network configuration applied"
}

# Set up firewall
setup_firewall() {
    log "Configuring firewall..."
    
    # Create basic iptables rules
    cat > /etc/iptables/rules.v4 << 'EOF'
*filter
:INPUT DROP [0:0]
:FORWARD ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]

# Allow loopback
-A INPUT -i lo -j ACCEPT

# Allow established connections
-A INPUT -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT

# Allow SSH (change port if needed)
-A INPUT -p tcp --dport 22 -m conntrack --ctstate NEW -m recent --set
-A INPUT -p tcp --dport 22 -m conntrack --ctstate NEW -m recent --update --seconds 60 --hitcount 4 -j DROP
-A INPUT -p tcp --dport 22 -j ACCEPT

# Allow web interface
-A INPUT -p tcp --dport 8080 -j ACCEPT

# Allow DHCP
-A INPUT -p udp --dport 67 -j ACCEPT

# Allow DNS
-A INPUT -p udp --dport 53 -j ACCEPT
-A INPUT -p tcp --dport 53 -j ACCEPT

# Allow WireGuard
-A INPUT -p udp --dport 51820 -j ACCEPT

# Allow ping
-A INPUT -p icmp --icmp-type echo-request -j ACCEPT

COMMIT

*nat
:PREROUTING ACCEPT [0:0]
:INPUT ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
:POSTROUTING ACCEPT [0:0]
COMMIT
EOF
    
    # Create IPv6 rules (mostly restrictive)
    cat > /etc/iptables/rules.v6 << 'EOF'
*filter
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]

# Allow loopback
-A INPUT -i lo -j ACCEPT

# Allow established connections
-A INPUT -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT

# Allow ICMPv6
-A INPUT -p ipv6-icmp -j ACCEPT

COMMIT
EOF
    
    # Install iptables-persistent if available
    if command -v iptables-restore &>/dev/null; then
        systemctl enable iptables
        success "Firewall rules configured"
    fi
}

# Set up automatic updates
setup_updates() {
    log "Configuring automatic updates..."
    
    # Enable update timer
    systemctl enable gateway-update.timer
    
    success "Automatic updates enabled"
}

# Generate initial gateway configuration
setup_gateway_config() {
    log "Creating initial gateway configuration..."
    
    cat > "$GATEWAY_CONFIG_DIR/gateway.json" << EOF
{
    "version": "1.0.0",
    "created": "$(date -Iseconds)",
    "network": {
        "lan_subnet": "192.168.100.0/24",
        "lan_ip": "192.168.100.1",
        "dhcp_range": "192.168.100.10-192.168.100.200"
    },
    "vpn": {
        "enabled": false,
        "vps_ip": "",
        "vps_public_key": ""
    },
    "security": {
        "ssh_port": 22,
        "web_port": 8080,
        "fail2ban_enabled": true
    },
    "features": {
        "dhcp_server": true,
        "dns_forwarding": true,
        "port_forwarding": true
    }
}
EOF
    
    success "Initial configuration created"
}

# Set up log rotation
setup_logging() {
    log "Setting up log rotation..."
    
    cat > /etc/logrotate.d/gateway << 'EOF'
/var/log/gateway/*.log {
    daily
    missingok
    rotate 7
    compress
    delaycompress
    notifempty
    copytruncate
}
EOF
    
    success "Log rotation configured"
}

# Enable and start services
setup_services() {
    log "Enabling gateway services..."
    
    # Copy service files
    cp /usr/share/gateway/services/*.service /etc/systemd/system/
    cp /usr/share/gateway/services/*.timer /etc/systemd/system/
    
    # Reload systemd
    systemctl daemon-reload
    
    # Enable gateway services
    systemctl enable gateway-manager.service
    systemctl enable gateway-web.service
    systemctl enable gateway-update.timer
    
    # Enable system services
    systemctl enable ssh
    systemctl enable systemd-networkd
    systemctl enable systemd-resolved
    
    success "Services enabled"
}

# Set file permissions
setup_permissions() {
    log "Setting up file permissions..."
    
    # Gateway directories
    chown -R root:gateway "$GATEWAY_CONFIG_DIR"
    chmod -R 750 "$GATEWAY_CONFIG_DIR"
    
    chown -R root:gateway "$GATEWAY_DATA_DIR"
    chmod -R 755 "$GATEWAY_DATA_DIR"
    
    # Log directory
    chown -R root:gateway /var/log/gateway
    chmod -R 755 /var/log/gateway
    
    # WireGuard directory
    chown -R root:root /etc/wireguard
    chmod -R 700 /etc/wireguard
    
    success "Permissions configured"
}

# Show completion message
show_completion_info() {
    local hostname=$(hostname)
    local ip_addr=$(ip route get 8.8.8.8 | awk '{print $7; exit}' 2>/dev/null || echo "unknown")
    
    cat << EOF

${GREEN}========================================
Gateway OS First Boot Setup Complete!
========================================${NC}

System Information:
  Hostname: $hostname
  IP Address: $ip_addr
  
Default Credentials:
  Username: admin
  Password: gateway123 (CHANGE IMMEDIATELY!)
  
Access Methods:
  SSH: ssh admin@$ip_addr
  Web: http://$ip_addr:8080
  
Next Steps:
  1. Change default password: passwd
  2. Configure VPN settings via web interface
  3. Set up SSH keys for secure access
  4. Review firewall settings
  
The system will reboot in 30 seconds to apply all changes...

EOF
}

# Main execution
main() {
    log "Starting first boot configuration..."
    
    setup_users
    setup_ssh
    setup_admin_user
    setup_system_identity
    setup_network
    setup_firewall
    setup_updates
    setup_gateway_config
    setup_logging
    setup_services
    setup_permissions
    
    # Mark first boot as complete
    touch "$COMPLETE_FLAG"
    echo "$(date -Iseconds)" > "$COMPLETE_FLAG"
    
    show_completion_info
    
    # Schedule reboot
    shutdown -r +1 "Rebooting to complete Gateway OS setup..."
    
    success "First boot setup completed successfully!"
}

# Run main function
main "$@"